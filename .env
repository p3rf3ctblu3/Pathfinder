# --- OPENSTREETMAP (OVERPASS API) ---
# No registration required! You query overpass-api.de directly using http requests.
# Just set an app identifier to prevent rate limits.
OSM_USER_AGENT=GreecePathfinderHackathonProject/1.0

# --- WAYMARKED TRAILS ---
# No API key required. You can crawl their open JSON database/relations natively 
# or overlay their map tiles directly in your UI maps.

# --- iNATURALIST API ---
# No API key required for GET/Read-only requests! Anyone can pull biodiversity data.
# You only need a token if you are writing or saving new species observations.

